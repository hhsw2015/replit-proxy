# ══════════════════════════════════════════════════════════════════════════════
# AI 反代服务配置  —  将此文件复制为 .env 并填入真实值
# ══════════════════════════════════════════════════════════════════════════════

# ── 必填：访问此代理的 Bearer Token（自定义任意字符串）────────────────────────
PROXY_API_KEY=your-custom-api-key-here

# ── Replit AI Integration（Replit 平台自动注入；本地部署填真实 Key）───────────
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1
AI_INTEGRATIONS_OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AI_INTEGRATIONS_ANTHROPIC_BASE_URL=https://api.anthropic.com
AI_INTEGRATIONS_ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── 服务端口（默认 8080）──────────────────────────────────────────────────────
PORT=8080

# ══════════════════════════════════════════════════════════════════════════════
# 多账号后端池（可选）——— 用于将多个 Replit 账号的配额聚合到一个入口
# ══════════════════════════════════════════════════════════════════════════════

# ── 主实例专用：管理密钥（用于调用 /v1/admin/* 接口）────────────────────────
# ADMIN_KEY=your-admin-key-here

# ── 静态后端列表（可选，JSON 数组，每项含 url/key/label）──────────────────────
# BACKENDS=[{"url":"https://sub1.replit.app","key":"sub1_key","label":"账号1"},{"url":"https://sub2.replit.app","key":"sub2_key","label":"账号2"}]

# ── 子实例专用：启动时自动向主实例注册自己 ────────────────────────────────────
# MASTER_URL=https://your-master.replit.app   # 主实例地址
# MASTER_ADMIN_KEY=your-admin-key-here        # 主实例的 ADMIN_KEY
# SELF_URL=https://this-sub.replit.app        # 本实例自己的公网地址
# SELF_LABEL=账号2                             # 可选备注名

# ══════════════════════════════════════════════════════════════════════════════
# 启动方式：
#   cp .env.example .env && pnpm install
#   pnpm --filter @workspace/api-server run dev
#
# 验证：
#   curl http://localhost:8080/v1/models -H "Authorization: Bearer <PROXY_API_KEY>"
#
# 管理后端池（主实例）：
#   # 查看所有后端
#   curl https://your-master.replit.app/v1/admin/backends -H "Authorization: Bearer <ADMIN_KEY>"
#   # 添加后端
#   curl -X POST https://your-master.replit.app/v1/admin/backends \
#     -H "Authorization: Bearer <ADMIN_KEY>" -H "Content-Type: application/json" \
#     -d '{"url":"https://sub.replit.app","key":"sub_key","label":"账号N"}'
#   # 删除后端
#   curl -X DELETE https://your-master.replit.app/v1/admin/backends \
#     -H "Authorization: Bearer <ADMIN_KEY>" -H "Content-Type: application/json" \
#     -d '{"url":"https://sub.replit.app"}'
# ══════════════════════════════════════════════════════════════════════════════
